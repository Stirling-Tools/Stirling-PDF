# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# OpenAI API (Optional - for GPT models)
OPENAI_API_KEY=sk-your-openai-key-here

# Model Configuration
SMART_MODEL=claude-sonnet-4-5-20250929
FAST_MODEL=claude-haiku-4-5-20251001

# GPT-5 Reasoning Settings (only used if SMART_MODEL is gpt-5)
# Options: minimal, low, medium, high, xhigh
SMART_MODEL_REASONING_EFFORT=medium
FAST_MODEL_REASONING_EFFORT=minimal

# GPT-5 Text Verbosity (only used if SMART_MODEL is gpt-5)
# Options: minimal, low, medium, high
SMART_MODEL_TEXT_VERBOSITY=medium
FAST_MODEL_TEXT_VERBOSITY=low

# PostHog Analytics
POSTHOG_API_KEY=your-posthog-key-here
POSTHOG_HOST=https://eu.i.posthog.com

# Backend Configuration
JAVA_BACKEND_URL=http://localhost:8080
JAVA_BACKEND_API_KEY=your-api-key
SECURITY_CUSTOMGLOBALAPIKEY=123456789

# Logging
EDIT_TOOL_LOG_RESPONSES=1
AI_LOG_RAW_ON_FAIL=1

# AI Streaming
AI_STREAMING=true
AI_PREVIEW_MAX_INFLIGHT=3
AI_REQUEST_TIMEOUT=70
