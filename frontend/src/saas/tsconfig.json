{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "../../",
    "paths": {
      "@app/*": [
        "src/saas/*",
        "src/proprietary/*",
        "src/core/*"
      ],
      "@proprietary/*": [
        "src/proprietary/*"
      ],
      "@core/*": [
        "src/core/*"
      ],
      "posthog-js/react": [
        "node_modules/posthog-js/react/dist/types/index.d.ts"
      ]
    }
  },
  "include": [
    "../global.d.ts",
    "../*.js",
    "../*.ts",
    "../*.tsx",
    "."
  ]
}
