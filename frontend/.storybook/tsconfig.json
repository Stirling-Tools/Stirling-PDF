{
  "compilerOptions": {
    "target": "es2022",
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@editor/*": [
        "../src/editor/desktop/*",
        "../src/editor/proprietary/*",
        "../src/editor/core/*"
      ],
      "@core/*": ["../src/editor/core/*"],
      "@proprietary/*": ["../src/editor/proprietary/*"],
      "@processor/*": ["../src/processor/proprietary/*"],
      "@public/*": ["../public/*"]
    },
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["./**/*"]
}
