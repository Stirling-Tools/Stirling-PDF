{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@app/*": ["src/cloud/*", "src/proprietary/*", "src/core/*"],
      "@cloud/*": ["src/cloud/*"],
      "@proprietary/*": ["src/proprietary/*"],
      "@core/*": ["src/core/*"],
      "@shared/*": ["../shared/*"]
    }
  },
  "exclude": ["src/core/**/*.test.ts*","src/core/**/*.spec.ts*","src/proprietary/**/*.test.ts*","src/proprietary/**/*.spec.ts*","src/saas","src/desktop"]
}
