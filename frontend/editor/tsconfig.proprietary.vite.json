{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@app/*": ["./src/proprietary/*", "./src/core/*"],
      "@portal/*": ["./src/portal/*"],
      "@proprietary/*": ["./src/proprietary/*"],
      "@core/*": ["./src/core/*"]
    }
  },
  "exclude": ["src/core/**/*.test.ts*", "src/core/**/*.spec.ts*", "src/desktop"]
}
