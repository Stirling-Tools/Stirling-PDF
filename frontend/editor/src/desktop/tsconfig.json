{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "../../",
    "paths": {
      "@app/*": [
        "src/desktop/*",
        "src/cloud/*",
        "src/proprietary/*",
        "src/core/*"
      ],
      "@cloud/*": ["src/cloud/*"],
      "@proprietary/*": ["src/proprietary/*"],
      "@core/*": ["src/core/*"],
      "@shared/*": ["../shared/*"]
    }
  },
  "include": [
    "../global.d.ts",
    "../*.js",
    "../*.ts",
    "../*.tsx",
    "../core/setupTests.ts",
    "."
  ]
}
