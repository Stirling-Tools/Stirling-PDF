{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@app/*": ["src/saas/*", "src/proprietary/*", "src/core/*"],
      "@proprietary/*": ["src/proprietary/*"],
      "@core/*": ["src/core/*"]
    }
  },
  "exclude": [
    "src/core/**/*.test.ts*",
    "src/core/**/*.spec.ts*",
    "src/proprietary/**/*.test.ts*",
    "src/proprietary/**/*.spec.ts*",
    "src/desktop",
    "node_modules"
  ]
}
