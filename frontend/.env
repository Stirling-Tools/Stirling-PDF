# Storybook-only environment (vite root = frontend/). The portal and editor apps
# load their own env from frontend/portal and frontend/editor, so nothing here
# touches them.
#
# Point apiClient.saas at a mock origin so the SaaS-backed billing stories
# (SubscribedPlanView, PaymentMethodCard, InvoicesList) resolve a base URL and
# their MSW handlers (which match "*/api/v1/payg/...") can intercept. The host
# never receives a real request — MSW answers first.
VITE_SAAS_API_URL=http://saas.mock
