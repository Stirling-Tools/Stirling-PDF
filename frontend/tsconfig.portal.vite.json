{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@app/*": ["src/portal/*", "src/shared/*"],
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": [
    "src",
    "src/global.d.ts",
    "vite.config.ts",
    "portal"
  ],
  "exclude": [
    "src/core",
    "src/proprietary",
    "src/desktop",
    "src/saas",
    "src/prototypes",
    "node_modules"
  ]
}
